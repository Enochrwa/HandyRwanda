# HandyRwanda Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (asyncpg)
DATABASE_URL=postgresql://Munyaneza:EnochLabs@localhost:5432/handyrwanda
# Individual fields (used as fallback if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=Munyaneza
DB_PASSWORD=EnochLabs
DB_NAME=handyrwanda

# ── Supabase Storage ───────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Redis (Upstash) ────────────────────────────────────────────────────────────
# Get these from: https://console.upstash.com
# Leave empty to use in-memory fallback (single-process dev only)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Get API key from: https://resend.com/api-keys
# Leave empty in dev — OTPs will print to console instead.
RESEND_API_KEY=re_your_key_here
# From address — must use a Resend-verified domain in production
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Translation (HuggingFace NLLB-200) ────────────────────────────────────────
# Used for Kinyarwanda ↔ English ↔ French translation in messages.
# Free tier. Leave empty to disable translation (messages stored untranslated).
HUGGINGFACE_API_TOKEN=hf_your_token_here
# Set to "local" if running a self-hosted NLLB/LibreTranslate server
TRANSLATION_BACKEND=huggingface
# URL for self-hosted translation server (only used when TRANSLATION_BACKEND=local)
# LOCAL_TRANSLATION_URL=http://localhost:8001/translate

# ── Firebase Cloud Messaging ───────────────────────────────────────────────────
# For native Android/iOS push notifications.
# Get from Firebase Console → Project Settings → Service Accounts
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVER_KEY=AAAA...  (legacy, for FCM legacy API)

# ── Push Notifications (Expo) ──────────────────────────────────────────────────
# Optional — improves delivery priority for Expo Go.
# Get from: https://expo.dev/accounts/your-account/settings/access-tokens
# EXPO_ACCESS_TOKEN=your-expo-token

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for production web app.
# Example: CORS_ORIGINS=https://handyrwanda.com,https://www.handyrwanda.com
CORS_ORIGINS=

# ── Environment ────────────────────────────────────────────────────────────────
ENV=development
# In dev: all OTP emails are redirected to this address (Resend test-mode restriction)
DEV_EMAIL_OVERRIDE=your-email@gmail.com
LOG_LEVEL=DEBUG

# ── Production overrides ───────────────────────────────────────────────────────
# Uncomment and set for production:
# ENV=production
# LOG_LEVEL=INFO
# DEV_EMAIL_OVERRIDE=
# PORT=8000
