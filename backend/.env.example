# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/handyrwanda

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" in prod. Controls email redirects, CORS strictness, etc.
ENV=development

# ── Supabase Storage (images) ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Bucket must exist in Supabase Storage with public read access
SUPABASE_BUCKET=handyrwanda-media

# ── Email — Resend ────────────────────────────────────────────────────────────
# Leave empty in dev to print OTPs to console (no Resend account needed).
# In prod: set RESEND_API_KEY + RESEND_FROM_EMAIL (verified domain required).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@handyrwanda.rw
# In dev with RESEND_API_KEY set, all emails are redirected to this address
# to avoid Resend's unverified-domain restriction.
DEV_EMAIL_OVERRIDE=your-resend-account-email@example.com

# ── Redis — Upstash (OTP rate limiting, cooldowns) ───────────────────────────
# Leave empty in dev to use in-memory fallback (resets on restart).
# In prod: create a free Upstash Redis database at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── CORS — production origins ─────────────────────────────────────────────────
# Comma-separated list of allowed origins added on top of the hardcoded list.
# Example: https://handyrwanda.rw,https://www.handyrwanda.rw
CORS_ORIGINS=

# ── Payment — Hybrid MTN MoMo / Airtel Money ─────────────────────────────────
# Phase 1 (now): manual verification — update these to your real business numbers
# once your MTN Mobile Money merchant account is registered.
# Phase 2 (later): replace with MTN_MOMO_API_KEY, MTN_MOMO_API_SECRET, etc.
# when API access is granted.
MTN_MOMO_RECEIVER_NUMBER=0788000000
AIRTEL_MONEY_RECEIVER_NUMBER=0730000000

# ── Expo Push Notifications ───────────────────────────────────────────────────
# Leave empty to skip push — tokens are stored but no-op if key missing.
EXPO_ACCESS_TOKEN=

# ── Firebase Cloud Messaging (FCM) ────────────────────────────────────────────
# Option A (preferred): Service account JSON string for FCM HTTP v1 API.
# Get from Firebase Console → Project Settings → Service Accounts → Generate key.
# Paste the entire JSON as a single-line string (escape quotes if needed).
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B (legacy fallback): Server key from Firebase Console → Cloud Messaging.
FIREBASE_SERVER_KEY=

# ── Escrow Auto-Release ────────────────────────────────────────────────────────
# Hours after artisan marks job done before escrow auto-releases to artisan.
# Client can confirm completion earlier; admin can override at any time.
ESCROW_AUTO_RELEASE_HOURS=48
