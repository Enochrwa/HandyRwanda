# HandyRwanda Mobile (.env) — Expo public environment variables
# Variables prefixed with EXPO_PUBLIC_ are bundled into the app.
# Copy to .env and fill in your values.

# ── Backend API URL ─────────────────────────────────────────────────────────────
# Development: leave empty — auto-detected from Expo Go LAN host.
# Physical device + Expo Go: leave empty (auto-detection uses hostUri).
# Production EAS Build: set to your deployed backend URL.
EXPO_PUBLIC_API_URL=

# Production example:
# EXPO_PUBLIC_API_URL=https://api.handyrwanda.com

# ── Firebase ────────────────────────────────────────────────────────────────────
# Native builds (EAS Build) require Firebase config files:
#   Android: android/app/google-services.json
#   iOS:     ios/GoogleService-Info.plist
#
# Download from: Firebase Console → Project Settings → Your Apps
#
# Expo Go testing does NOT require these files.
# Firebase push notifications only work in native (EAS) builds.
#
# Steps to enable Firebase push:
#   1. Create Firebase project at https://console.firebase.google.com
#   2. Add Android app (package: com.enochlabs.handyrwanda)
#   3. Add iOS app (bundle ID: com.enochlabs.handyrwanda)
#   4. Download config files and place them at the paths above
#   5. Run: eas build --platform android   (or ios)
