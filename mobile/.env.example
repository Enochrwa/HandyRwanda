# File: mobile/.env.example
#
# Copy to .env and fill in values before running.
#
# EXPO_PUBLIC_API_URL — backend base URL (no trailing slash).
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  Expo Go on a physical Android/iOS device (most common dev setup)       │
# │  → Use your machine's LAN IP, e.g. http://192.168.1.x:8000             │
# │  → The app auto-detects the LAN host from Metro when this var is unset, │
# │    but setting it explicitly avoids surprises.                           │
# │                                                                          │
# │  Android emulator                                                        │
# │  → Use http://10.0.2.2:8000 (emulator special alias for host loopback)  │
# │                                                                          │
# │  Web (Vite dev server proxied to same machine)                          │
# │  → http://localhost:8000                                                 │
# └─────────────────────────────────────────────────────────────────────────┘
EXPO_PUBLIC_API_URL=http://192.168.1.x:8000
