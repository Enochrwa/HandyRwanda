{
  "expo": {
    "name": "HandyRwanda",
    "slug": "handyrwanda",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "scheme": "handyrwanda"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "scheme": "handyrwanda"
    },
    "web": {},
    "plugins": [
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      "expo-router",
      "expo-notifications"
    ],
    "scheme": "handyrwanda",
    "entryPoint": "node_modules/expo-router/entry.js"
  }
}
