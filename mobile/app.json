{
  "expo": {
    "name": "HandyRwanda",
    "slug": "handyrwanda",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "scheme": "handyrwanda",
      "bundleIdentifier": "com.handyrwanda.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.handyrwanda.app",
      "scheme": "handyrwanda",
      "adaptiveIcon": {
        "backgroundColor": "#FF6B35"
      },
      "googleServicesFile": "./android/app/google-services.json",
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "notification": {
        "icon": "./assets/notification-icon.png",
        "color": "#FF6B35",
        "androidMode": "default",
        "androidCollapsedTitle": "#{unread_notifications} new updates"
      }
    },
    "web": {},
    "plugins": [
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      "expo-router",
      "@react-native-async-storage/async-storage",
      "@react-native-community/netinfo",
      [
        "expo-image-manipulator",
        {}
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF6B35",
          "defaultChannel": "default",
          "sounds": [
            "./assets/notification-sound.wav"
          ]
        }
      ]
    ],
    "scheme": "handyrwanda",
    "entryPoint": "node_modules/expo-router/entry.js",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "786750836514"
      }
    }
  }
}
