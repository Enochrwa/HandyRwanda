{
  "name": "handyrwanda-monorepo",
  "type": "module",
  "private": true,
  "workspaces": [
    "web",
    "mobile",
    "backend"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "concurrently --names \"web,api\" --prefix-colors \"cyan,yellow\" \"npm run dev -w web\" \"npm run dev:backend\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:py": "cd backend && python -m black .",
    "type-check": "npm run type-check --workspaces --if-present",
    "test": "npm test -w web && cd backend && PYTHONPATH=. pytest",
    "dev:web": "npm run dev -w web",
    "dev:mobile": "npm run start -w mobile",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --reload --port 8000 --host 0.0.0.0",
    "dev:all": "concurrently --names \"web,api,mobile\" --prefix-colors \"cyan,yellow,green\" \"npm run dev -w web\" \"npm run dev:backend\" \"npm run dev:mobile\"",
    "backend:install": "cd backend && pip install -r requirements.txt",
    "backend:install:prod": "cd backend && pip install -r requirements-prod.txt"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@types/react": "~18.2.0",
    "@types/react-dom": "~18.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-universe": "^15.2.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "uuid": "^11.1.1"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "vite": "^6.3.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "~18.2.0",
    "@types/react-dom": "~18.2.0",
    "nativewind": {
      "tailwindcss": "3.4.19"
    },
    "react-native-css-interop": {
      "tailwindcss": "3.4.19"
    }
  }
}
