# HandyRwanda Web Frontend Environment Variables
# Copy to .env (dev) or .env.production (prod) and fill in your values.

# ── Backend API URL ─────────────────────────────────────────────────────────────
# Development: leave empty — auto-detects http://localhost:8000
# Production: set to your deployed backend URL (no trailing slash)
VITE_API_URL=

# Production example:
# VITE_API_URL=https://api.handyrwanda.com

# ── App Configuration ──────────────────────────────────────────────────────────
# App name shown in browser tab and meta tags
VITE_APP_NAME=HandyRwanda
